NEXT_PUBLIC_WEBHOOK_URL=<YOUR_SMEE_IO_WEBHOOK_URL_HERE>
PORT=7443
NEXT_PUBLIC_PORT=7443
API_URL=http://localhost:8080/api
WEBSOCKET_URL=ws://localhost:8080/ws
WEBHOOK_URL=http://localhost:8080/webhook
WEBSITE_DOMAIN=http://localhost:3000
# Better Auth URL for client-side (browser) - used by Better Auth client
# Should point to Better Auth service URL (e.g., http://localhost:9090 or https://auth.example.com)
NEXT_PUBLIC_AUTH_URL=http://localhost:9090
# Better Auth service URL for server-side (Next.js API routes) - used by Better Auth service layer
# In Docker, this is automatically set via docker-compose.yml environment variable
# For local development, should match NEXT_PUBLIC_AUTH_URL (base URL without /api/auth)
# In production Docker: http://nixopus-auth:9090
# In staging Docker: http://nixopus-staging-auth:9090
AUTH_SERVICE_URL=http://localhost:9090

# Password login flag (runtime, not build-time)
# When true (default): Shows standard email/password login
# When false (for cloud/managed): Shows OTP-based login
PASSWORD_LOGIN_ENABLED=true

# AI Agent URL (optional)
# When set, enables the AI chat feature powered by the agent service
# Self-hosted users can point this to their own agent instance
# Leave empty to disable AI features
NEXT_PUBLIC_AGENT_URL=
